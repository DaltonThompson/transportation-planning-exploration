# Copy to .env and fill in as needed

# Override the OSM place names (default: Albany + Rensselaer + Schenectady Counties).
# Must be a JSON array when specifying multiple places:
# OSM_PLACE=["Albany County, New York, USA","Rensselaer County, New York, USA"]
# Single-county override (plain string also accepted):
# OSM_PLACE=Albany County, New York, USA

# Duration defaults (minutes)
# DEFAULT_DURATION_MINUTES=60
# MAX_DURATION_MINUTES=120

# Simulation constants (rarely changed)
# DECAY_FACTOR=0.95
# CONGESTION_FLOOR=0.2

# GTFS snap rejection threshold (meters)
# GTFS_SNAP_MAX_METERS=100.0
